    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/svelte": "^5.2.4",
    "@testing-library/jest-dom": "^6.5.0",
    "@types/node": "^22.7.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.44.0",
    "globals": "^15.11.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "prettier-plugin-svelte": "^3.2.7",
